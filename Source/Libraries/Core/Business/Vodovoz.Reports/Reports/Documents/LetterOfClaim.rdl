  <DataElementName>Report</DataElementName>
  <DataElementStyle>AttributeNormal</DataElementStyle>
  <DataSets>
    <DataSet Name="Organization">
      <Query>
        <DataSourceName>DS1</DataSourceName>
        <CommandText>select
	o.full_name as full_name,
	o.INN as inn,
	o.OGRN as ogrn,
	ov.jur_address as jur_address,
	(select p.`number` from phones p where p.org_id = o.id limit 1) as phone,
    e.last_name AS leader_last_name,
    e.name AS leader_name,
    e.patronymic AS leader_patronymic,
    CONCAT(
        UPPER(LEFT(e.name, 1)), 
        '.', 
        IF(e.patronymic IS NOT NULL AND e.patronymic &lt;&gt; '', 
           CONCAT(UPPER(LEFT(e.patronymic, 1)), '.'), 
           ''
        ), 
        ' ', 
        e.last_name
    ) AS leader_short_name
from organizations o 
join organization_versions ov on o.id = ov.organization_id AND ov.start_date &lt;= NOW() AND (ov.end_date is null OR ov.end_date &gt;= NOW())
left join employees e on ov.leader_id = e.id
where
	o.id = @organization_id
order by ov.id desc
limit 1;</CommandText>
        <QueryParameters>
          <QueryParameter Name="organization_id">
            <Value>={?organization_id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="full_name">
          <DataField>full_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="inn">
          <DataField>inn</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="ogrn">
          <DataField>ogrn</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="jur_address">
          <DataField>jur_address</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="phone">
          <DataField>phone</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="leader_last_name">
          <DataField>leader_last_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="leader_name">
          <DataField>leader_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="leader_patronymic">
          <DataField>leader_patronymic</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="leader_short_name">
          <DataField>leader_short_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Signatures">
      <Query>
        <DataSourceName>DS1</DataSourceName>
        <CommandText>SELECT 
	binary_file as leader
FROM stored_resource
WHERE id = 
	(SELECT 
		 ov.signature_leader_id
	FROM organizations o
	JOIN organization_versions ov ON o.id = ov.organization_id AND ov.start_date &lt;= NOW() AND (ov.end_date is null OR ov.end_date &gt;= NOW())
	where o.id = @organization_id
	order by ov.id 
	limit 1);</CommandText>
        <QueryParameters>
          <QueryParameter Name="organization_id">
            <Value>={?organization_id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="leader">
          <DataField>leader</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Stamp">
      <Query>
        <DataSourceName>DS1</DataSourceName>
        <CommandText>select sr.binary_file as image
from organizations o
join stored_resource sr ON o.stamp_id = sr.id
WHERE o.id = @organization_id</CommandText>
        <QueryParameters>
          <QueryParameter Name="organization_id">
            <Value>={?organization_id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="image">
          <DataField>image</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Client">
      <Query>
        <DataSourceName>DS1</DataSourceName>
        <CommandText>select
	c.full_name as full_name,
	c.inn as inn,
	c.jur_address as jur_address,
	cc.`number` as contract_number,
	cc.issue_date  as contract_date,
	CONCAT(
        'от «', 
        DAY(cc.issue_date), 
        '» ', 
        CASE MONTH(cc.issue_date)
            WHEN 1 THEN 'января'
            WHEN 2 THEN 'февраля'
            WHEN 3 THEN 'марта'
            WHEN 4 THEN 'апреля'
            WHEN 5 THEN 'мая'
            WHEN 6 THEN 'июня'
            WHEN 7 THEN 'июля'
            WHEN 8 THEN 'августа'
            WHEN 9 THEN 'сентября'
            WHEN 10 THEN 'октября'
            WHEN 11 THEN 'ноября'
            WHEN 12 THEN 'декабря'
        END, 
        ' ', 
        YEAR(cc.issue_date), 
        ' года'
    ) AS formatted_contract_date
from counterparty c
left join counterparty_contract cc on c.id = cc.counterparty_id and cc.organization_id = @organization_id and cc.contract_type = 'Cashless'
where
	c.id = @client_id
order by cc.id desc
limit 1
;</CommandText>
        <QueryParameters>
          <QueryParameter Name="client_id">
            <Value>={?client_id}</Value>
          </QueryParameter>
          <QueryParameter Name="organization_id">
            <Value>={?organization_id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="full_name">
          <DataField>full_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="inn">
          <DataField>inn</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="contract_date">
          <DataField>contract_date</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="formatted_contract_date">
          <DataField>formatted_contract_date</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="jur_address">
          <DataField>jur_address</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="contract_number">
          <DataField>contract_number</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Creator">
      <Query>
        <DataSourceName>DS1</DataSourceName>
        <CommandText>select
IFNULL(GET_PARAMETER('ClaimDocument.CreatedBy'),'-') as creator,
IFNULL(GET_PARAMETER('ClaimDocument.CreatorPhone'),'-') as creator_phone
;</CommandText>
      </Query>
      <Fields>
        <Field Name="creator">
          <DataField>creator</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="creator_phone">
          <DataField>creator_phone</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <DataSources>
