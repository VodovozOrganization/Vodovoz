  <PageFooter>
    <Height>0pt</Height>
    <PrintOnFirstPage>false</PrintOnFirstPage>
    <PrintOnLastPage>false</PrintOnLastPage>
  </PageFooter>
  <DataElementName>Report</DataElementName>
  <DataElementStyle>AttributeNormal</DataElementStyle>
  <DataSets >
    <DataSet Name="Organization">
      <Query>
        <DataSourceName></DataSourceName>
        <CommandText>select
	o.full_name as full_name,
	o.INN as inn,
	o.OGRN as ogrn,
	ov.jur_address as jur_address,
	(select p.`number` from phones p where p.org_id = o.id limit 1) as phone,
    e.last_name AS leader_last_name,
    e.name AS leader_name,
    e.patronymic AS leader_patronymic,
    CONCAT(
        UPPER(LEFT(e.name, 1)), 
        '.', 
        IF(e.patronymic IS NOT NULL AND e.patronymic &lt;&gt; '', 
           CONCAT(UPPER(LEFT(e.patronymic, 1)), '.'), 
           ''
        ), 
        e.last_name
    ) AS leader_short_name
from organizations o 
join organization_versions ov on o.id = ov.organization_id
left join employees e on ov.leader_id = e.id
where
	o.id = @organization_id
order by ov.id desc
limit 1;</CommandText>
        <QueryParameters>
          <QueryParameter Name="organization_id">
            <Value>={?organization_id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="full_name">
          <DataField>full_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="inn">
          <DataField>inn</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="ogrn">
          <DataField>ogrn</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="jur_address">
          <DataField>jur_address</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="phone">
          <DataField>phone</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="leader_last_name">
          <DataField>leader_last_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="leader_name">
          <DataField>leader_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="leader_patronymic">
          <DataField>leader_patronymic</DataField>
          <TypeName>System.String</TypeName>
        </Field>
        <Field Name="leader_short_name">
          <DataField>leader_short_name</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Signatures">
      <Query>
        <DataSourceName></DataSourceName>
        <CommandText>SELECT 
	binary_file as leader
FROM stored_resource
WHERE id = 
	(SELECT 
		 ov.signature_leader_id
	FROM organizations o
	JOIN organization_versions ov ON o.id = ov.organization_id 
	where o.id = @organization_id
	order by ov.id 
	limit 1);</CommandText>
        <QueryParameters>
          <QueryParameter Name="organization_id">
            <Value>={?organization_id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="leader">
          <DataField>leader</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Stamp">
      <Query>
        <DataSourceName></DataSourceName>
        <CommandText>select sr.binary_file as image
from organizations o
join stored_resource sr ON o.stamp_id = sr.id
WHERE o.id = @organization_id</CommandText>
        <QueryParameters>
          <QueryParameter Name="organization_id">
            <Value>={?organization_id}</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="image">
          <DataField>image</DataField>
          <TypeName>System.String</TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters >
    <ReportParameter Name="organization_id">
      <DataType>Integer</DataType>
      <Nullable>false</Nullable>
      <AllowBlank>false</AllowBlank>
      <MultiValue>false</MultiValue>
      <Prompt />
    </ReportParameter>
  </ReportParameters>
</Report>