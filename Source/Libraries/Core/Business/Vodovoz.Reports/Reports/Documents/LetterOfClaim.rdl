<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <Description></Description>
  <Author></Author>
  <PageHeight>11.69in</PageHeight>
  <PageWidth>8.27in</PageWidth>
  <Width>482pt</Width>
  <TopMargin>15mm</TopMargin>
  <LeftMargin>20mm</LeftMargin>
  <RightMargin>20mm</RightMargin>
  <BottomMargin>15mm</BottomMargin>
  <PageHeader>
    <Height>0pt</Height>
    <PrintOnFirstPage>false</PrintOnFirstPage>
    <PrintOnLastPage>false</PrintOnLastPage>
  </PageHeader>
  <Body>
    <Height>720.9pt</Height>
    <Columns>1</Columns>
    <ReportItems>
      <Textbox Name="AppendixLabel">
        <Height>14pt</Height>
        <Width>120pt</Width>
        <Value>Приложение 1</Value>
        <Left>0pt</Left>
        <Top>0pt</Top>
        <Style>
          <FontFamily>Arial</FontFamily>
          <FontSize>10pt</FontSize>
          <VerticalAlign>Middle</VerticalAlign>
          <BorderStyle>
            <Default>None</Default>
          </BorderStyle>
          <BorderColor />
          <BorderWidth />
        </Style>
      </Textbox>
      <!-- Шапка организации: таблица (без рамки) -->
      <Table Name="OrgHeaderTable">
        <Style>
          <BorderStyle>
            <Default>None</Default>
          </BorderStyle>
          <BorderColor />
          <BorderWidth />
        </Style>
        <TableColumns>
          <TableColumn>
            <Width>477.3pt</Width>
          </TableColumn>
        </TableColumns>
        <Header>
          <TableRows>
            <TableRow>
              <Height>22pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="OrgName">
                      <Value>={full_name}</Value>
                      <Style>
                        <FontFamily>Arial</FontFamily>
                        <FontSize>14pt</FontSize>
                        <FontWeight>Bold</FontWeight>
                        <TextAlign>Center</TextAlign>
                        <VerticalAlign>Middle</VerticalAlign>
                        <BorderStyle>
                          <Default>None</Default>
                        </BorderStyle>
                        <BorderColor />
                        <BorderWidth />
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
            <TableRow>
              <Height>26pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="OrgDetails">
                      <Value>="ИНН/ОГРН " + {inn} + "/" + {ogrn}  + " Юридический адрес: " + {jur_address} + ", т: 8 " + {phone}</Value>
                      <CanGrow>true</CanGrow>
                      <Style>
                        <FontFamily>Arial</FontFamily>
                        <FontSize>9pt</FontSize>
                        <FontStyle>Italic</FontStyle>
                        <TextAlign>Center</TextAlign>
                        <VerticalAlign>Middle</VerticalAlign>
                        <BorderStyle>
                          <Default>None</Default>
                        </BorderStyle>
                        <BorderColor />
                        <BorderWidth />
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
          </TableRows>
        </Header>
        <Left>0pt</Left>
        <Top>18pt</Top>
        <DataSetName>Organization</DataSetName>
      </Table>
      <!-- Таблица исходящего номера и адресата (2 колонки × 3 строки, с рамкой) -->
      <Table Name="HeaderInfoTable">
        <Style>
          <BorderStyle>
            <Default>Solid</Default>
          </BorderStyle>
          <BorderColor>
            <Default>Black</Default>
          </BorderColor>
          <BorderWidth>
            <Default>0.5pt</Default>
          </BorderWidth>
        </Style>
        <TableColumns>
          <TableColumn>
            <Width>190pt</Width>
          </TableColumn>
          <TableColumn>
            <Width>292pt</Width>
          </TableColumn>
        </TableColumns>
        <Header>
          <TableRows>
            <!-- Строка 1: Исх. № б/н | получатель -->
            <TableRow>
              <Height>42.0pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="HeaderCell00">
                      <Value>="Исх. № б/н

" 
+ "От «" + Day(Today()) 
+ "» " 
+  Choose(Month(Today()), "января", "февраля", "марта", "апреля", "мая", "июня", "июля", "августа", "сентября", "октября", "ноября", "декабря") 
+ " " 
+ Year(Today()) &amp; " года"</Value>
                      <Style>
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Top</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>Solid</Default>
                          <Right>Solid</Right>
                          <Bottom>Solid</Bottom>
                          <Left>Solid</Left>
                          <Top>Solid</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingTop>2pt</PaddingTop>
                        <PaddingBottom>2pt</PaddingBottom>
                      </Style>
                      <CanGrow>true</CanGrow>
                    </Textbox>
                  </ReportItems>
                </TableCell>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="HeaderCell01">
                      <Value>={full_name}
+ "
"
+ {jur_address}
+ ", "
+ {inn}</Value>
                      <Style>
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Middle</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>Solid</Default>
                          <Bottom>Solid</Bottom>
                          <Left>Solid</Left>
                          <Right>Solid</Right>
                          <Top>Solid</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingTop>2pt</PaddingTop>
                        <PaddingBottom>2pt</PaddingBottom>
                      </Style>
                      <CanGrow>true</CanGrow>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
            <TableRow>
              <Height>20.1pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Textbox16">
                      <Value></Value>
                      <Style xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Top</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>Solid</Default>
                          <Right>Solid</Right>
                          <Bottom>Solid</Bottom>
                          <Left>Solid</Left>
                          <Top>Solid</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingTop>2pt</PaddingTop>
                        <PaddingBottom>2pt</PaddingBottom>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Textbox17">
                      <Value></Value>
                      <Style xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Middle</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>Solid</Default>
                          <Bottom>Solid</Bottom>
                          <Left>Solid</Left>
                          <Right>Solid</Right>
                          <Top>Solid</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingTop>2pt</PaddingTop>
                        <PaddingBottom>2pt</PaddingBottom>
                      </Style>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
            <!-- Строка 2: поле номера | контакт получателя -->
            <!-- Строка 3: дата | адрес получателя -->
          </TableRows>
        </Header>
        <Left>0pt</Left>
        <Top>75pt</Top>
        <DataSetName>Client</DataSetName>
      </Table>
      <Textbox Name="DocTitle">
        <Height>25.76pt</Height>
        <Width>482.00pt</Width>
        <Value>ПРЕТЕНЗИЯ</Value>
        <Left>0.00pt</Left>
        <Top>139.00pt</Top>
        <Style>
          <FontFamily>Arial</FontFamily>
          <FontSize>12pt</FontSize>
          <FontWeight>Bold</FontWeight>
          <TextAlign>Center</TextAlign>
          <VerticalAlign>Middle</VerticalAlign>
          <TextDecoration>None</TextDecoration>
          <BorderStyle>
            <Default>None</Default>
          </BorderStyle>
          <BorderColor />
          <BorderWidth />
        </Style>
      </Textbox>
      <Textbox Name="Attachments">
        <Height>44pt</Height>
        <Width>482pt</Width>
        <Value>Приложение:
Счет на оплату</Value>
        <Left>0.7pt</Left>
        <Top>506.5pt</Top>
        <CanGrow>true</CanGrow>
        <Style>
          <FontFamily>Arial</FontFamily>
          <FontSize>10pt</FontSize>
          <FontStyle>Italic</FontStyle>
          <VerticalAlign>Top</VerticalAlign>
          <BorderStyle>
            <Default>None</Default>
          </BorderStyle>
          <BorderColor />
          <BorderWidth />
        </Style>
      </Textbox>
      <Textbox Name="SignatureLine">
        <Height>15pt</Height>
        <Width>482pt</Width>
        <Value>="Генеральный директор                                   " + First({leader_short_name}, 'Organization')</Value>
        <Left>0.7pt</Left>
        <Top>567.7pt</Top>
        <Style>
          <FontFamily>Arial</FontFamily>
          <FontSize>10pt</FontSize>
          <FontWeight>Bold</FontWeight>
          <VerticalAlign>Middle</VerticalAlign>
          <BorderStyle>
            <Default>None</Default>
          </BorderStyle>
          <BorderColor />
          <BorderWidth />
        </Style>
      </Textbox>
      <Image Name="Image1" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
        <Height>60.21pt</Height>
        <Width>80.53pt</Width>
        <Left>134.3pt</Left>
        <Top>539.2pt</Top>
        <Style>
          <BorderStyle />
          <BorderColor />
          <BorderWidth />
          <FontFamily>Calibri</FontFamily>
        </Style>
        <Source>Database</Source>
        <Value>=First({leader}, "Signatures")</Value>
        <Sizing>Fit</Sizing>
        <ZIndex>2</ZIndex>
        <Visibility>
          <Hidden>={?hide_signature}</Hidden>
        </Visibility>
        <MIMEType>image/png</MIMEType>
      </Image>
      <Image Name="Image2" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
        <Height>102.39pt</Height>
        <Width>112.93pt</Width>
        <Left>30.4pt</Left>
        <Top>579.0pt</Top>
        <Style>
          <BorderStyle />
          <BorderColor />
          <BorderWidth />
        </Style>
        <Source>Database</Source>
        <Value>=First( {image} , "Stamp" )</Value>
        <Sizing>Fit</Sizing>
        <MIMEType>image/png</MIMEType>
        <Visibility>
          <Hidden>={?hide_signature}</Hidden>
        </Visibility>
        <ZIndex>2</ZIndex>
      </Image>
      <Table Name="Table1" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
        <Style>
          <BorderStyle>
            <Default>None</Default>
            <Left>None</Left>
            <Right>None</Right>
            <Top>None</Top>
            <Bottom>None</Bottom>
          </BorderStyle>
          <BorderColor>
            <Default>Black</Default>
          </BorderColor>
          <BorderWidth>
            <Default>1pt</Default>
            <Left>1pt</Left>
            <Right>1pt</Right>
            <Top>1pt</Top>
            <Bottom>1pt</Bottom>
          </BorderWidth>
        </Style>
        <TableColumns>
          <TableColumn>
            <Width>483.6pt</Width>
          </TableColumn>
        </TableColumns>
        <Header>
          <TableRows>
            <!-- Строка 1: Исх. № б/н | получатель -->
            <!-- Строка 2: поле номера | контакт получателя -->
            <TableRow>
              <Height>22.2pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Textbox3">
                      <Value>="      Настоящим, сообщаем Вам, о наличии за "
+ First({full_name}, 'Client')
+ " задолженности перед " 
+ First({full_name}, 'Organization') 
+ ", возникшей по договору "
+ First({contract_number}, 'Client')
+ " "
+ First({formatted_contract_date}, 'Client')</Value>
                      <Style>
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Middle</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>None</Default>
                          <Right>None</Right>
                          <Bottom>None</Bottom>
                          <Left>None</Left>
                          <Top>None</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingBottom>2pt</PaddingBottom>
                        <PaddingTop>2pt</PaddingTop>
                      </Style>
                      <CanGrow>true</CanGrow>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
            <TableRow>
              <Height>18pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Textbox7">
                      <Value>="      Размер задолженности, составляет:  " + {?debt_sum_string}</Value>
                      <Style xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Middle</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>None</Default>
                          <Right>None</Right>
                          <Bottom>None</Bottom>
                          <Left>None</Left>
                          <Top>None</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingBottom>2pt</PaddingBottom>
                        <PaddingTop>2pt</PaddingTop>
                      </Style>
                      <CanGrow>true</CanGrow>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
            <TableRow>
              <Height>41.4pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Textbox8">
                      <Value>      Согласно, положениям ст. 309, 310, 314 Гражданского кодекса Российской Федерации обязательства сторон договорных правоотношений должны исполняться надлежащим образом в соответствии с требованиями законодательства и условиями договора.</Value>
                      <Style xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Middle</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>None</Default>
                          <Right>None</Right>
                          <Bottom>None</Bottom>
                          <Left>None</Left>
                          <Top>None</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingBottom>2pt</PaddingBottom>
                        <PaddingTop>2pt</PaddingTop>
                      </Style>
                      <CanGrow>true</CanGrow>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
            <TableRow>
              <Height>21.9pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Textbox9">
                      <Value>      Обязательство должно исполняться точно в срок, установленный соглашением сторон.</Value>
                      <Style xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Middle</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>None</Default>
                          <Right>None</Right>
                          <Bottom>None</Bottom>
                          <Left>None</Left>
                          <Top>None</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingBottom>2pt</PaddingBottom>
                        <PaddingTop>2pt</PaddingTop>
                      </Style>
                      <CanGrow>true</CanGrow>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
            <TableRow>
              <Height>38.4pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Textbox10">
                      <Value>      При этом Российским законодательством не допускается односторонний отказ от исполнения обязательства, а также изменение его условий в одностороннем порядке ст.310 гк рф.</Value>
                      <Style xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Middle</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>None</Default>
                          <Right>None</Right>
                          <Bottom>None</Bottom>
                          <Left>None</Left>
                          <Top>None</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingBottom>2pt</PaddingBottom>
                        <PaddingTop>2pt</PaddingTop>
                      </Style>
                      <CanGrow>true</CanGrow>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
            <TableRow>
              <Height>36.6pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Textbox11">
                      <Value>="      Предлагаем Вам в добровольном порядке в срок до " 
+ "«" 
+ Day(DateAdd("m", 1, Today())) 
+ "» " 
+ Choose(Month(DateAdd("m", 1, Today())), "января", "февраля", "марта", "апреля", "мая", "июня", "июля", "августа", "сентября", "октября", "ноября", "декабря") 
+ " " 
+ Year(DateAdd("m", 1, Today())) 
+ " года "
+ "погасить возникшую задолженность на общую сумму: "
+ {?debt_sum_string}</Value>
                      <Style xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Middle</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>None</Default>
                          <Right>None</Right>
                          <Bottom>None</Bottom>
                          <Left>None</Left>
                          <Top>None</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingBottom>2pt</PaddingBottom>
                        <FontWeight>Bold</FontWeight>
                        <PaddingTop>2pt</PaddingTop>
                      </Style>
                      <CanGrow>true</CanGrow>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
            <TableRow>
              <Height>55.9pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Textbox12">
                      <Value>      На основании изложенного и руководствуясь статьями 309, 310, 314 гк рф, просим вас оплатить указанную задолженность. В противном случае мы будем вынуждены обратиться в Арбитражный суд о взыскании задолженности в принудительном порядке и закрыть все поставки нашей продукции.</Value>
                      <Style xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Middle</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
                        <BorderStyle>
                          <Default>None</Default>
                          <Right>None</Right>
                          <Bottom>None</Bottom>
                          <Left>None</Left>
                          <Top>None</Top>
                        </BorderStyle>
                        <BorderColor>
                          <Default>Black</Default>
                        </BorderColor>
                        <BorderWidth>
                          <Default>1pt</Default>
                          <Left>1pt</Left>
                          <Right>1pt</Right>
                          <Top>1pt</Top>
                          <Bottom>1pt</Bottom>
                        </BorderWidth>
                        <PaddingRight>2pt</PaddingRight>
                        <PaddingBottom>2pt</PaddingBottom>
                        <FontWeight>Bold</FontWeight>
                        <Color>Red</Color>
                        <PaddingTop>2pt</PaddingTop>
                      </Style>
                      <CanGrow>true</CanGrow>
                    </Textbox>
                  </ReportItems>
                </TableCell>
              </TableCells>
            </TableRow>
            <TableRow>
              <Height>33.4pt</Height>
              <TableCells>
                <TableCell>
                  <ReportItems>
                    <Textbox Name="Textbox13">
                      <Value>      В этом случае сумма Вашей задолженности будет увеличена на сумму госпошлины, пени за просрочку оплаты и иных судебных расходов.</Value>
                      <Style xmlns="http://schemas.microsoft.com/sqlserver/reporting/2005/01/reportdefinition">
                        <FontFamily>Arial</FontFamily>
                        <FontSize>10pt</FontSize>
                        <VerticalAlign>Middle</VerticalAlign>
                        <PaddingLeft>2pt</PaddingLeft>
