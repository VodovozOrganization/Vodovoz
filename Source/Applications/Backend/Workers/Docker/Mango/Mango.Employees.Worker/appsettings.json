{
  "ConnectionStrings": {
	"DefaultConnection": ""
  },
  "DatabaseConnectionSettings": {
	"ServerName": "",
	"Port": 3306,
	"DatabaseName": "",
	"UserName": "",
	"Password": ""
  },
  "NLog": {
	"autoReload": true,
	"autoShutdown": true,
	"extensions": [
	  {
		"assembly": "NLog.Targets.Seq"
	  },
	  {
		"assembly": "NLog.Web.AspNetCore"
	  }
	],
	"targets": {
	  "async": true,
	  "console": {
		"type": "ColoredConsole",
		"layout": "${longdate} ${uppercase:${level}} ${message}|ActivityId=${activity:property=TraceId}",
		"wordHighlightingRules": [
		  {
			"text": "DEBUG",
			"foregroundColor": "DarkGreen"
		  },
		  {
			"text": "WARNING",
			"foregroundColor": "Yellow"
		  },
		  {
			"text": "ERROR",
			"foregroundColor": "Red"
		  },
		  {
			"text": "FATAL",
			"foregroundColor": "Red"
		  }
		]
	  },
	  "seq": {
		"type": "BufferingWrapper",
		"bufferSize": 200,
		"flushTimeout": 2000,
		"slidingTimeout": false,
		"target": {
		  "type": "Seq",
		  "serverUrl": "",
		  "apiKey": "",
		  "properties": [
			{
			  "name": "Source",
			  "value": "${Logger}"
			},
			{
			  "name": "ThreadId",
			  "value": "${ThreadId}",
			  "as": "number"
			},
			{
			  "name": "MachineName",
			  "value": "${MachineName}"
			}
		  ]
		}
	  }
	},
	"rules": [
	  {
		"logger": "*",
		"minLevel": "Info",
		"writeTo": "seq"
	  },
	  {
		"logger": "Microsoft.*",
		"minLevel": "Trace"
	  },
	  {
		"logger": "*",
		"minLevel": "Trace",
		"writeTo": "console"
	  }
	]
  }
}
