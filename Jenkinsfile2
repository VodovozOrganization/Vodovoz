@NonCPS
def takeNextPublishingProject() {
	synchronized(getPublishingProjectQueueLock()) {
		if (!PUBLISHING_PROJECT_QUEUE) {
			return null
		}

		def nextProject = PUBLISHING_PROJECT_QUEUE.remove(0)
		return nextProject.collectEntries { key, value -> [key, value] }
	}
}

@NonCPS
def getPublishingProjectQueueLock() {
	return 'vodovoz-publishing-project-queue-lock'.intern()
}

@NonCPS
def getBuildStopLock() {
	return 'vodovoz-build-stop-lock'.intern()
}

@NonCPS
def requestBuildStop(String reason = '') {
	synchronized(getBuildStopLock()) {
		BUILD_STOP_REQUESTED = true
	}
	if (reason?.trim()) {
		echo "Build stop requested: ${reason}"
	}
}

@NonCPS
def isBuildStopRequested() {
	synchronized(getBuildStopLock()) {
		return BUILD_STOP_REQUESTED
	}
}

@NonCPS
def isBuildInterrupted() {
	return Thread.currentThread().isInterrupted()
}

def CleanupAbortedBuildResourcesOnNodes() {
	def availableNodes = AVAILABLE_DOCKER_BUILD_NODES
	def pipelineContainerLabel = "${PIPELINE_CONTAINER_LABEL_PREFIX}-${env.BUILD_NUMBER}"
	def maxContainerAgeSeconds = PIPELINE_CONTAINER_MAX_AGE_SECONDS as int
	if (!availableNodes) {
		echo "AVAILABLE_DOCKER_BUILD_NODES is empty, discovering nodes by label ${NODE_DOCKER_BUILD} for cleanup"
		availableNodes = getDockerBuildNodesBySecondaryLabel(NODE_DOCKER_BUILD)
	}

	if (!availableNodes) {
		echo "No available nodes found for abort cleanup"
		return
	}

	def cleanupBranches = [:]
	availableNodes.each { nodeInfo ->
		def nodeSelector = "${nodeInfo.secondaryLabel}"
		def branchName = "Abort cleanup ${nodeSelector}"

		cleanupBranches[branchName] = {
			node(nodeSelector) {
				def workspaceBase = env.WORKSPACE ?: ''
				sh """
					set +e
					echo "Abort cleanup on node ${nodeSelector}"
					now_epoch=\$(date +%s)
					oldest_allowed_epoch=\$((now_epoch - ${maxContainerAgeSeconds}))

					remove_container() {
						cid="\$1"
						if [ -z "\$cid" ]; then
							return 0
						fi
						docker exec "\$cid" sh -c 'kill -9 -1' || true
						docker rm -f "\$cid" || true
					}

					echo "Removing containers for current build label ${pipelineContainerLabel}"
					for cid in \$(docker ps -aq --filter 'label=${PIPELINE_CONTAINER_LABEL_KEY}=${pipelineContainerLabel}' 2>/dev/null); do
						remove_container "\$cid"
					done

					echo "Removing ${PIPELINE_CONTAINER_LABEL_PREFIX} containers older than ${maxContainerAgeSeconds} second(s)"
					for cid in \$(docker ps -aq --filter 'label=${PIPELINE_CONTAINER_LABEL_KEY}' 2>/dev/null); do
						pipeline_label=\$(docker inspect --format '{{ index .Config.Labels "${PIPELINE_CONTAINER_LABEL_KEY}" }}' "\$cid" 2>/dev/null || true)
						case "\$pipeline_label" in
							${PIPELINE_CONTAINER_LABEL_PREFIX}-*) ;;
							*) continue ;;
						esac

						created_epoch=\$(docker inspect --format '{{ index .Config.Labels "${PIPELINE_CONTAINER_CREATED_LABEL_KEY}" }}' "\$cid" 2>/dev/null || true)
						case "\$created_epoch" in
							''|*[!0-9]*) continue ;;
						esac

						if [ "\$created_epoch" -le "\$oldest_allowed_epoch" ]; then
							remove_container "\$cid"
						fi
					done

					echo "Pruning dangling images"
					docker image prune -f || true

					echo "Pruning BuildKit cache"
					docker builder prune -af || true
				""".stripIndent()

				if (workspaceBase?.trim()) {
					sh """
						set +e
						echo "Removing workspace container dirs under ${workspaceBase}"
						rm -rf "${workspaceBase}@container-"* || true
						rm -rf "${workspaceBase}@determine-projects" || true
					""".stripIndent()
				}
			}
		}
	}

	parallel cleanupBranches
}

def CheckoutMainRepositoryWithoutSubmodules(referenceRepositoryPath) {
	checkout changelog: false, poll: false, scm: [
		$class: 'GitSCM',
		branches:  [[name: 'hotfix/jenkins-services-pipeline']],
		doGenerateSubmoduleConfigurations: false,
		userRemoteConfigs: [[
			url: 'https://github.com/VodovozOrganization/Vodovoz.git'
		]],
		extensions: [
			[$class: 'CloneOption',
				shallow: false,
				noTags: false,
				reference: "${referenceRepositoryPath}/Vodovoz.git"
			],
			[$class: 'SubmoduleOption',
				disableSubmodules: true
			]
		]
	]
}

def DeterminePublishingProjectDirs(String profileName) {
	def projectDirsRaw = sh(
		script: """
			set -eu

			scriptDir=\"\$PWD\"
			applicationsPath=\"\$scriptDir/Source/Applications\"

			if [ ! -d \"\$applicationsPath\" ]; then
				echo \"Error: Directory not found: \$applicationsPath\" >&2
				exit 1
			fi

			find \"\$applicationsPath\" -type f -name \"RepositorySettings.props\" |
				while IFS= read -r filepath; do
					projectDir=\"\$(dirname \"\$filepath\")\"
					if [ -f \"\$projectDir/jenkins-ignore\" ]; then
						continue
					fi
					echo \"\${projectDir#\$scriptDir/}\"
				done |
				sort -u
		""".stripIndent(),
		returnStdout: true
	).trim()

	if (!projectDirsRaw) {
		return []
	}

	return projectDirsRaw.split("\\r?\\n").findAll { it?.trim() }
}

def DiscoverProjectFilePath(String projectDir) {
	def projectFile = sh(
		script: """
			set -eu
			ls -1 \"${projectDir}\"/*.csproj 2>/dev/null | head -n 1 || true
		""".stripIndent(),
		returnStdout: true
	).trim()

	if (!projectFile) {
		error("Не найден .csproj в директории ${projectDir}")
	}

	return projectFile
}

def ReadXmlProperty(String filePath, String propertyName) {
	if (!fileExists(filePath)) {
		error("Не найден файл: ${filePath}")
	}

	def xmlText = readFile(file: filePath)
	def propertyRegex = "(?s)<${propertyName}>(.*?)</${propertyName}>"
	def matcher = (xmlText =~ propertyRegex)
	def value = matcher.find() ? matcher.group(1).trim() : ''

	if (!value) {
		error("В файле ${filePath} не найдено значение PropertyGroup/${propertyName}")
	}

	return value
}

def CloneMirror(String url, String cache, int depth = 0) {

    def name = url.tokenize('/').last().replace('.git','')
    def path = "${cache}/${name}.git"

    if (!fileExists(path)) {
        sh "git clone --mirror ${url} ${path}"
    } else {
        sh "git -C ${path} remote update"
    }

	// Ищем сабмодули только у корневого репозитория.
	// Сабмодули внутри сабмодулей (depth > 0) не обрабатываем.
	if (depth == 0) {
		def hasModules = sh(
			script: "git -C ${path} show HEAD:.gitmodules >/dev/null 2>&1",
			returnStatus: true
		)

		if (hasModules == 0) {

			def subUrls = sh(
				script: "git -C ${path} show HEAD:.gitmodules | grep url | awk '{print \$3}'",
				returnStdout: true
			).trim().split("\\n")

			for (sub in subUrls) {
				if (sub?.trim()) {
					CloneMirror(sub.trim(), cache, depth + 1)
				}
			}
		}
	}
}



def CheckoutInContainer(referenceRepositoryPath) {

	checkout changelog: false, poll: false, scm: [
		$class: 'GitSCM',
		branches: [[name: 'hotfix/jenkins-services-pipeline']],
		doGenerateSubmoduleConfigurations: false,

		userRemoteConfigs: [[
			url: 'https://github.com/VodovozOrganization/Vodovoz.git'
			// credentialsId: '21dbdc92-7ffd-47e2-a198-303233bb0fe4'
		]],

		extensions: [

			// reference clone ТОЛЬКО для основного repo
			[$class: 'CloneOption',
				shallow: false,
				noTags: false,
				reference: "${referenceRepositoryPath}/Vodovoz.git"
			],

			// отключаем автоинициализацию сабмодулей
			[$class: 'SubmoduleOption',
				disableSubmodules: true
			]
		]
	]

	echo "=== Checkout submodules from reference repository ==="
	echo "referenceRepositoryPath(host): ${referenceRepositoryPath}"
	echo "REFERENCE_REPOSITORY_MOUNT_PATH(container): ${REFERENCE_REPOSITORY_MOUNT_PATH}"
	CheckoutSubmodulesFromReference(referenceRepositoryPath)

	echo "=== Source/Libraries/External directories ==="
	sh 'find Source/Libraries/External -maxdepth 1 -mindepth 1 -type d | sort || echo "(directory not found)"'
}

def CheckoutSubmodulesFromReference(referenceRepositoryPath) {
	sh """
		set -eu

		referenceRepositoryPath="${referenceRepositoryPath}"

		if ! test -f .gitmodules; then
			echo "No submodules found in .gitmodules"
			exit 0
		fi

		echo "referenceRepositoryPathExists=\$(test -d "\$referenceRepositoryPath" && echo true || echo false); path=\$referenceRepositoryPath"

		git submodule sync --quiet --recursive || true

		git config -f .gitmodules --get-regexp '^submodule\\..*\\.path\$' | while IFS= read -r row; do
			pathKey="\${row%% *}"
			submodulePath="\${row#* }"
			urlKey="\${pathKey%.path}.url"
			submoduleUrl="\$(git config -f .gitmodules --get "\$urlKey")"
			repoName="\$(basename "\$submoduleUrl" .git)"
			referenceMirrorPath="\$referenceRepositoryPath/\$repoName.git"

			echo "Preparing submodule \$submodulePath"

			if test -d "\$referenceMirrorPath"; then
				git submodule update --init --jobs 4 --reference "\$referenceMirrorPath" -- "\$submodulePath"
			else
				git submodule update --init --jobs 4 -- "\$submodulePath"
			fi
		done
	""".stripIndent()
}

