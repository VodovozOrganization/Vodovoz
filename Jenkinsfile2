stage('Checkout nodes') {
	def availableNodes = getNodesByLabel(NODE_DOCKER_BUILD)
    
    def parallelCheckouts = [:]
    
    availableNodes.each { nodeName ->
        parallelCheckouts[nodeName] = {
            node(nodeName) {
                def REFERENCE_REPOSITORY_PATH = "${env.JENKINS_HOME_NODE}/workspace/_VODOVOZ_REFERENCE_REPOSITORY"
				CheckoutReference(REFERENCE_REPOSITORY_PATH)
            }
        }
    }
    
    parallel parallelCheckouts
}

stage('Checkout in containers') {
	def availableNodes = getNodesByLabel(NODE_DOCKER_BUILD)
	if (!availableNodes) {
		error("–ù–µ –Ω–∞–π–¥–µ–Ω–æ –¥–æ—Å—Ç—É–ø–Ω—ã—Ö –Ω–æ–¥ —Å —Ç–µ–≥–æ–º ${NODE_DOCKER_BUILD} –¥–ª—è checkout –≤ –∫–æ–Ω—Ç–µ–π–Ω–µ—Ä–∞—Ö")
	}
	def parallelCheckouts = [:]

	availableNodes.each { nodeName ->
		parallelCheckouts[nodeName] = {
			node(nodeName) {
				def referenceRepositoryPath = "${env.JENKINS_HOME_NODE}/workspace/_VODOVOZ_REFERENCE_REPOSITORY"
				def mountArgs = "--entrypoint='' -v ${referenceRepositoryPath}:${REFERENCE_REPOSITORY_MOUNT_PATH}:ro"

				docker.image(CHECKOUT_CONTAINER_IMAGE).inside(mountArgs) {
					EnsureGitInContainer()
					deleteDir()
					// Git plugin may execute on host launcher (JENKINS-30600), so reference path must be host-visible.
					CheckoutInContainer(referenceRepositoryPath)
				}
			}
		}
	}

	parallel parallelCheckouts
}

