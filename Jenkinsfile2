// Setup

@NonCPS
def getDockerBuildNodesBySecondaryLabel(dockerBuildLabel) {
    def nodes = []
    def usedSecondaryLabels = [] as Set

    Jenkins.instance.computers.each { computer ->
    	def node = computer.node
    	if (node == null || !computer.online) {
    		return
    	}

    	def labels = (node.labelString ?: '').tokenize(' ') as Set
    	if (!labels.contains(dockerBuildLabel)) {
    		return
    	}

    	if (labels.size() != 2) {
    		error("Нода '${node.name}' должна иметь ровно 2 метки (включая '${dockerBuildLabel}'), сейчас: ${labels.join(' ')}")
    	}

    	def secondaryLabels = labels.findAll { it != dockerBuildLabel }
    	if (secondaryLabels.size() != 1) {
    		error("Не удалось определить вторую метку для ноды '${node.name}', метки: ${labels.join(' ')}")
    	}

    	def secondaryLabel = secondaryLabels[0]
    	if (usedSecondaryLabels.contains(secondaryLabel)) {
    		error("Вторая метка '${secondaryLabel}' встречается у нескольких нод. Требуется уникальная вторая метка на ноду")
    	}

    	usedSecondaryLabels.add(secondaryLabel)
    	nodes.add([nodeName: node.name, secondaryLabel: secondaryLabel])
    }

    return nodes
}

