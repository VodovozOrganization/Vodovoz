// подготовка референсного репозитория на нодах, чтобы использовать его позже в контейнерах для ускорения git clone
stage('Checkout nodes') {
	def availableNodes = getDockerBuildNodesBySecondaryLabel(NODE_DOCKER_BUILD)
	if (!availableNodes) {
		error("Не найдено доступных нод с меткой ${NODE_DOCKER_BUILD}")
	}
    
    def parallelCheckouts = [:]
    
    availableNodes.each { nodeInfo ->
		def nodeSelector = "${nodeInfo.secondaryLabel}"
		echo "nodeSelector='${nodeSelector}'"

		parallelCheckouts[nodeSelector] = {
			node(nodeSelector) {
                def referenceRepositoryPath = "${env.JENKINS_HOME_NODE}/workspace/_VODOVOZ_REFERENCE_REPOSITORY"
				CloneMirror("https://github.com/VodovozOrganization/Vodovoz.git", referenceRepositoryPath)
            }
        }
    }
    
    parallel parallelCheckouts
}

stage('Checkout and build in containers') {
	def availableNodes = getDockerBuildNodesBySecondaryLabel(NODE_DOCKER_BUILD)
	if (!availableNodes) {
		error("Не найдено доступных нод с тегом ${NODE_DOCKER_BUILD} для работы в контейнерах")
	}
	def parallelBranches = [:]

	availableNodes.each { nodeInfo ->
		def nodeSelector = "${nodeInfo.secondaryLabel}"
		echo "nodeSelector='${nodeSelector}'"

		for (int i = 1; i <= CONTAINERS_PER_NODE; i++) {
			def containerIndex = i
			def branchName = "${nodeInfo.secondaryLabel} #${containerIndex}"
			parallelBranches[branchName] = {
				node(nodeSelector) {
					def referenceRepositoryPath = "${env.JENKINS_HOME_NODE}/workspace/_VODOVOZ_REFERENCE_REPOSITORY"
					def workspaceSuffix = "container-${containerIndex}"
					def cid = null

					ws("${env.WORKSPACE}@${workspaceSuffix}") {
						try {
							stage("Start container ${branchName}") {
								def workspaceDir = pwd()
								def containerName = "build-${env.BUILD_NUMBER}-${containerIndex}-${nodeSelector.replaceAll('[^a-zA-Z0-9]', '-')}"
								cid = sh(
									script: """
										docker run -d \
										  --name ${containerName} \
										  -v ${referenceRepositoryPath}:${REFERENCE_REPOSITORY_MOUNT_PATH}:ro \
										  -v ${workspaceDir}:/work \
										  -w /work \
										  ${CHECKOUT_CONTAINER_IMAGE} \
										  tail -f /dev/null
									""".stripIndent(),
									returnStdout: true
								).trim()
								echo "Started container: ${cid}"
							}

							stage("Checkout ${branchName}") {
								// Checkout выполняется через Jenkins Git plugin на хосте (JENKINS-30600).
								// Рабочий каталог смонтирован в контейнер как /work, поэтому код доступен внутри.
								CheckoutInContainer(referenceRepositoryPath)
							}

							stage("Build ${branchName}") {
								sh "docker exec ${cid} bash -c 'echo BUILD_TEST: container ${branchName} is alive'"
							}
						} finally {
							if (cid?.trim()) {
								sh "docker rm -f ${cid} || true"
							}
						}
					}
				}
			}
		}
	}
	parallel parallelBranches
}

