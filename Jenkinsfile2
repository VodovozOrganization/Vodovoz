// ą┐ąŠą┤ą│ąŠčéąŠą▓ą║ą░ čĆąĄčäąĄčĆąĄąĮčüąĮąŠą│ąŠ čĆąĄą┐ąŠąĘąĖčéąŠčĆąĖčÅ ąĮą░ ąĮąŠą┤ą░čģ, čćčéąŠą▒čŗ ąĖčüą┐ąŠą╗čīąĘąŠą▓ą░čéčī ąĄą│ąŠ ą┐ąŠąĘąČąĄ ą▓ ą║ąŠąĮčéąĄą╣ąĮąĄčĆą░čģ ą┤ą╗čÅ čāčüą║ąŠčĆąĄąĮąĖčÅ git clone
stage('Checkout nodes') {
	def availableNodes = AVAILABLE_DOCKER_BUILD_NODES
	if (!availableNodes) {
		error("ąØąĄ ąĮą░ą╣ą┤ąĄąĮąŠ ą┤ąŠčüčéčāą┐ąĮčŗčģ ąĮąŠą┤ čü ą╝ąĄčéą║ąŠą╣ ${NODE_DOCKER_BUILD}")
	}
    
    def parallelCheckouts = [:]
    
    availableNodes.each { nodeInfo ->
		def nodeSelector = "${nodeInfo.secondaryLabel}"
		echo "nodeSelector='${nodeSelector}'"

		parallelCheckouts[nodeSelector] = {
			node(nodeSelector) {
                def referenceRepositoryPath = "${env.JENKINS_HOME_NODE}/workspace/_VODOVOZ_REFERENCE_REPOSITORY"
				CloneMirror("https://github.com/VodovozOrganization/Vodovoz.git", referenceRepositoryPath)
            }
        }
    }
    
    parallel parallelCheckouts
}

stage('Discover publishing projects') {
	def firstNode = AVAILABLE_DOCKER_BUILD_NODES[0]
	node(firstNode.secondaryLabel) {
		def referenceRepositoryPath = "${env.JENKINS_HOME_NODE}/workspace/_VODOVOZ_REFERENCE_REPOSITORY"

		ws("${env.WORKSPACE}@discover-projects") {
			deleteDir()
			CheckoutMainRepositoryWithoutSubmodules(referenceRepositoryPath)

			def projectDirs = DiscoverPublishingProjectDirs(PUBLISH_PROFILE_FILE)
			if (!projectDirs) {
				error("ąØąĄ ąĮą░ą╣ą┤ąĄąĮąŠ ą┐čĆąŠąĄą║čéąŠą▓ čü ą┐čĆąŠčäąĖą╗ąĄą╝ ą┐čāą▒ą╗ąĖą║ą░čåąĖąĖ ${PUBLISH_PROFILE_FILE}")
			}

			def discoveredProjects = []
			projectDirs.each { projectDir ->
				def projectPath = DiscoverProjectFilePath(projectDir)
				def repositorySettingsPath = "${projectDir}/RepositorySettings.props"
				def publishProfilePath = "${projectDir}/Properties/PublishProfiles/${PUBLISH_PROFILE_FILE}"

				def containerRepository = ReadXmlProperty(repositorySettingsPath, 'ContainerRepository')
				def publishImageTag = ReadXmlProperty(publishProfilePath, 'PublishImageTag')

				discoveredProjects.add([
					projectPath: projectPath,
					containerRepository: containerRepository,
					publishImageTag: publishImageTag
				])
			}

			PUBLISHING_PROJECTS = discoveredProjects
			PUBLISHING_PROJECT_PATHS = discoveredProjects.collect { it.projectPath }

			echo "ąØą░ą╣ą┤ąĄąĮąŠ ą┐čĆąŠąĄą║čéąŠą▓ ą┤ą╗čÅ ą┐čāą▒ą╗ąĖą║ą░čåąĖąĖ: ${PUBLISHING_PROJECTS.size()}"
			PUBLISHING_PROJECTS.each { p ->
				echo "projectPath=${p.projectPath}; containerRepository=${p.containerRepository}; publishImageTag=${p.publishImageTag}"
			}
		}
	}
}

stage('Checkout and build in containers') {
	def availableNodes = getDockerBuildNodesBySecondaryLabel(NODE_DOCKER_BUILD)
	if (!availableNodes) {
		error("ąØąĄ ąĮą░ą╣ą┤ąĄąĮąŠ ą┤ąŠčüčéčāą┐ąĮčŗčģ ąĮąŠą┤ čü čéąĄą│ąŠą╝ ${NODE_DOCKER_BUILD} ą┤ą╗čÅ čĆą░ą▒ąŠčéčŗ ą▓ ą║ąŠąĮčéąĄą╣ąĮąĄčĆą░čģ")
	}
	def parallelBranches = [:]
	def totalBuilders = availableNodes.size() * CONTAINERS_PER_NODE

	availableNodes.eachWithIndex { nodeInfo, nodeIndex ->
		def nodeSelector = "${nodeInfo.secondaryLabel}"
		echo "nodeSelector='${nodeSelector}'"

		for (int i = 1; i <= CONTAINERS_PER_NODE; i++) {
			def containerIndex = i
			def builderIndex = nodeIndex * CONTAINERS_PER_NODE + (containerIndex - 1)
			def assignedProjects = getProjectsForBuilder(PUBLISHING_PROJECTS, builderIndex, totalBuilders)
			def branchName = "${nodeInfo.secondaryLabel} #${containerIndex}"
			parallelBranches[branchName] = {
				node(nodeSelector) {
					def referenceRepositoryPath = "${env.JENKINS_HOME_NODE}/workspace/_VODOVOZ_REFERENCE_REPOSITORY"
					def workspaceSuffix = "container-${containerIndex}"
					def cid = null

					ws("${env.WORKSPACE}@${workspaceSuffix}") {
						try {
							stage("Start container ${branchName}") {
								def workspaceDir = pwd()
								def containerName = "build-${env.BUILD_NUMBER}-${containerIndex}-${nodeSelector.replaceAll('[^a-zA-Z0-9]', '-')}"
								withCredentials([usernamePassword(credentialsId: DOCKER_REGISTRY_CREDENTIALS_ID, usernameVariable: 'DOCKER_REGISTRY_USERNAME', passwordVariable: 'DOCKER_REGISTRY_PASSWORD')]) {
									sh "echo \"\$DOCKER_REGISTRY_PASSWORD\" | docker login ${DOCKER_REGISTRY_URL} -u \"\$DOCKER_REGISTRY_USERNAME\" --password-stdin"
								}

								cid = sh(
									script: """
										docker run -d \
										  --pull always \
										  --name ${containerName} \
										  -v /var/run/docker.sock:/var/run/docker.sock \
										  -v ${referenceRepositoryPath}:${REFERENCE_REPOSITORY_MOUNT_PATH}:ro \
										  -v ${workspaceDir}:/work \
										  -w /work \
										  ${CHECKOUT_CONTAINER_IMAGE} \
										  tail -f /dev/null
									""".stripIndent(),
									returnStdout: true
								).trim()
								echo "Started container: ${cid}"
							}

							stage("Checkout ${branchName}") {
								withCredentials([usernamePassword(credentialsId: DOCKER_REGISTRY_CREDENTIALS_ID, usernameVariable: 'DOCKER_REGISTRY_USERNAME', passwordVariable: 'DOCKER_REGISTRY_PASSWORD')]) {
									sh "docker exec ${cid} sh -c 'command -v docker >/dev/null 2>&1 || (apt-get update && apt-get install -y docker.io)'"
									withEnv(["CID=${cid}", "REGISTRY_URL=${DOCKER_REGISTRY_URL}"]) {
										sh '''
											docker exec -e REG_USER="$DOCKER_REGISTRY_USERNAME" -e REG_PASS="$DOCKER_REGISTRY_PASSWORD" -e REGISTRY_URL="$REGISTRY_URL" "$CID" sh -c 'echo "$REG_PASS" | docker login "$REGISTRY_URL" -u "$REG_USER" --password-stdin'
										'''.stripIndent()
									}
								}

								// Checkout ą▓čŗą┐ąŠą╗ąĮčÅąĄčéčüčÅ čćąĄčĆąĄąĘ Jenkins Git plugin ąĮą░ čģąŠčüčéąĄ (JENKINS-30600).
								// ąĀą░ą▒ąŠčćąĖą╣ ą║ą░čéą░ą╗ąŠą│ čüą╝ąŠąĮčéąĖčĆąŠą▓ą░ąĮ ą▓ ą║ąŠąĮčéąĄą╣ąĮąĄčĆ ą║ą░ą║ /work, ą┐ąŠčŹčéąŠą╝čā ą║ąŠą┤ ą┤ąŠčüčéčāą┐ąĄąĮ ą▓ąĮčāčéčĆąĖ.
								CheckoutInContainer(referenceRepositoryPath)
							}

							stage("Build ${branchName}") {
								echo "Builder ${builderIndex + 1}/${totalBuilders}: ${assignedProjects.size()} project(s) assigned"
								for (projectInfo in assignedProjects) {
									def projectPath = projectInfo.projectPath
									def imageRepository = projectInfo.containerRepository
									def imageTag = projectInfo.publishImageTag
									def projectDll = projectPath.tokenize('/').last().replace('.csproj', '.dll')
									def publishDir = "/work/.publish/${projectDll.replace('.dll', '')}"
									def imageFullName = "${DOCKER_REGISTRY_URL}/${imageRepository}:${imageTag}"

									stage("${imageRepository}:${imageTag}") {
										echo "Build and push: ${projectPath} -> ${DOCKER_REGISTRY_URL}/${imageRepository}:${imageTag}"
										def cmdCreateDir = "docker exec ${cid} sh -c 'mkdir -p \"${publishDir}\"'"
										echo "CMD: ${cmdCreateDir}"
										sh cmdCreateDir

										def cmdPublish = "docker exec ${cid} sh -c 'dotnet publish \"${projectPath}\" -c Release -r linux-x64 --self-contained false -o \"${publishDir}\" /maxcpucount:4'"
										echo "CMD: ${cmdPublish}"
										sh cmdPublish

										def cmdWriteDockerfile = """docker exec ${cid} sh -c 'cat > "${publishDir}/Dockerfile" <<EOF
FROM mcr.microsoft.com/dotnet/runtime:5.0
WORKDIR /app
COPY . .
ENTRYPOINT ["dotnet","${projectDll}"]
EOF'"""
										echo "CMD: write Dockerfile to ${publishDir}/Dockerfile"
										sh cmdWriteDockerfile

										def cmdBuild = "docker exec ${cid} sh -c 'docker build -t \"${imageFullName}\" \"${publishDir}\"'"
										echo "CMD: ${cmdBuild}"
										sh cmdBuild

										def cmdPush = "docker exec ${cid} sh -c 'docker push \"${imageFullName}\"'"
										echo "CMD: ${cmdPush}"
										sh cmdPush
									}
								}
							}
						} finally {
							if (cid?.trim()) {
								sh "docker rm -f ${cid} || true"
							}
							try {
								deleteDir()
							} catch (e) {
								echo "Workspace cleanup failed: ${e}"
							}
						}
					}
				}
			}
		}
	}
	parallel parallelBranches
}

