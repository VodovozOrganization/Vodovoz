// Setup

@NonCPS
def getNodesByLabel(label) {
    def nodes = []
    Jenkins.instance.computers.each { computer ->
        if (computer.node.labelString.contains(label) && computer.online) {
            nodes.add(computer.node.name)
        }
    }
    return nodes
}

