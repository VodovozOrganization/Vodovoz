		echo "WORKSPACE=$PWD"
		echo "Listing host reference repository path"
		ls -la "${referenceRepositoryPath}" || true
		echo "Listing container mount-like path on host (if exists)"
		ls -la "${REFERENCE_REPOSITORY_MOUNT_PATH}" || echo "Path does not exist on host: ${REFERENCE_REPOSITORY_MOUNT_PATH}"
	""".stripIndent()
	CheckoutSubmodulesFromReference(referenceRepositoryPath)

	echo "=== Source/Libraries/External directories ==="
	sh 'find Source/Libraries/External -maxdepth 1 -mindepth 1 -type d | sort || echo "(directory not found)"'
}

def CheckoutSubmodulesFromReference(referenceRepositoryPath) {
	def submoduleRowsRaw = sh(
		script: "git config -f .gitmodules --get-regexp '^submodule\\..*\\.path\$' || true",
		returnStdout: true
	).trim()

	def referenceRootExists = (sh(script: "test -d \"${referenceRepositoryPath}\"", returnStatus: true) == 0)
	echo "referenceRepositoryPathExists=${referenceRootExists}; path=${referenceRepositoryPath}"

	if (!submoduleRowsRaw) {
		echo "No submodules found in .gitmodules"
		return
	}

	def submoduleRows = submoduleRowsRaw.split("\\r?\\n")

	for (row in submoduleRows) {
		def pair = row.trim().split("\\s+", 2)
		if (pair.size() != 2) {
			continue
		}

		def pathKey = pair[0].trim()
		def submodulePath = pair[1].trim()
		def urlKey = pathKey.replace('.path', '.url')
		def submoduleUrl = sh(script: "git config -f .gitmodules --get ${urlKey}", returnStdout: true).trim()
		def repoName = submoduleUrl.tokenize('/').last().replace('.git', '')
		def referenceMirrorPath = "${referenceRepositoryPath}/${repoName}.git"
		def referenceMirrorExists = (sh(script: "test -d \"${referenceMirrorPath}\"", returnStatus: true) == 0)

		sh "echo Preparing submodule ${submodulePath}"
		sh "echo submoduleUrl=${submoduleUrl}"
		sh "echo repoName=${repoName}"
		sh "echo referenceRepositoryPath=${referenceRepositoryPath}"
		sh "echo referenceMirrorPath=${referenceMirrorPath}"
		sh "echo referenceMirrorExists=${referenceMirrorExists}"
		if (!referenceMirrorExists) {
			sh "echo 'Reference mirror is missing. Available entries in reference path:'"
			sh "ls -la \"${referenceRepositoryPath}\" || true"
		}
		sh "git submodule init -- ${submodulePath}"
		sh "git submodule sync -- ${submodulePath}"
		if (referenceMirrorExists) {
			sh "git submodule update --init --reference ${referenceMirrorPath} -- ${submodulePath}"
		} else {
			sh "echo 'Running submodule update without --reference'"
			sh "git submodule update --init -- ${submodulePath}"
		}
	}
}

