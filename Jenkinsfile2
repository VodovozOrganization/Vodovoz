def BuildService(service) {
	sh """
		msbuild ${service.Path} \
			-restore:True \
			/t:Publish \
			/p:Configuration=Release \
			/p:PublishProfile=${PUBLISH_PROFILE} \
			/maxcpucount:6
	""".stripIndent()
}

def EnsureGitInContainer() {
	sh '''
		set -e
		if ! command -v git >/dev/null 2>&1; then
			apt-get update
			apt-get install -y git
		fi
	'''.stripIndent()
}

